# Supabase (URL + anon for client SDK + service role for server-side writes)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin login — single-user hardcoded password
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Quickomate identity (shown on every contract; admin gets BCC'd at this email)
NEXT_PUBLIC_PROVIDER_NAME=Vasu Gupta
NEXT_PUBLIC_PROVIDER_EMAIL=vasu@quickomate.com

# Base URL of the deployed app (used in email links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Resend (transactional email). Until you verify your domain, From must be onboarding@resend.dev
RESEND_API_KEY=
RESEND_FROM=Quickomate <hello@quickomate.com>
